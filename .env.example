# ZurOt OIDC - local environment template
# Copy to .env.local and fill values from BitWarden.

NEXT_PUBLIC_CONVEX_URL=https://your-convex-deployment.convex.cloud
CONVEX_DEPLOYMENT=dev:your-deployment-name
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_replace_me
CLERK_SECRET_KEY=sk_test_replace_me
# Must match the deploy origin exactly. Dev: http://localhost:3000
ISSUER=https://auth.zurot.org
# Public landing page sends users to this app entrypoint for profile flow.
# Dev: http://localhost:3000
# Prod example: https://app.zurot.org
NEXT_PUBLIC_APP_URL=http://localhost:3000

# PEM values are shown here in escaped single-line format.
# Prefer storing and retrieving full PEM values from BitWarden.
RSA_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nREPLACE_WITH_PRIVATE_KEY_CONTENT\n-----END PRIVATE KEY-----"
RSA_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\nREPLACE_WITH_PUBLIC_KEY_CONTENT\n-----END PUBLIC KEY-----"

RESEND_API_KEY=
RESEND_FROM_EMAIL=support@domain.com

# Bunny Stream media upload, webhook, and native TV playback.
BUNNY_STREAM_LIBRARY_ID=your-stream-library-id
BUNNY_STREAM_API_KEY=your-stream-library-api-key
BUNNY_STREAM_READ_ONLY_API_KEY=your-stream-read-only-api-key
BUNNY_STREAM_CDN_HOSTNAME=your-stream-hostname.b-cdn.net
BUNNY_STREAM_CDN_TOKEN_KEY=your-cdn-token-key
BUNNY_STREAM_WEBHOOK_FORWARD_SECRET=shared-next-to-convex-secret
BUNNY_STREAM_OPERATOR_SECRET=operator-only-secret
MEDIA_API_FORWARD_SECRET=shared-next-to-convex-media-secret
# Development only. Production must use BUNNY_STREAM_CDN_TOKEN_KEY.
BUNNY_STREAM_ALLOW_DIRECT_PLAY=false
