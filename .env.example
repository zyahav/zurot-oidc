# ZurOt OIDC - local environment template
# Copy to .env.local and fill values from BitWarden.

NEXT_PUBLIC_CONVEX_URL=https://your-convex-deployment.convex.cloud
CONVEX_DEPLOYMENT=dev:your-deployment-name
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_replace_me
CLERK_SECRET_KEY=sk_test_replace_me
ISSUER=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# PEM values are shown here in escaped single-line format.
# Prefer storing and retrieving full PEM values from BitWarden.
RSA_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nREPLACE_WITH_PRIVATE_KEY_CONTENT\n-----END PRIVATE KEY-----"
RSA_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\nREPLACE_WITH_PUBLIC_KEY_CONTENT\n-----END PUBLIC KEY-----"
